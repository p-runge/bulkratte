{
  "name": "bulkratte",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "dotenv -e .env -- next dev --turbopack --hostname localhost",
    "dev:tunnel": "dotenv -e .env -- tsx --tsconfig tsconfig.scripts.json scripts/tunnel.ts",
    "build": "next build",
    "start": "dotenv -e .env -- next start",
    "lint": "next lint",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "db:push": "drizzle-kit push --config ./drizzle.config.ts",
    "db:backup": "bash scripts/db/backup.sh",
    "db:import-core": "bash scripts/db/import-core.sh",
    "db:seed": "tsx scripts/db/seed.ts",
    "db:seed-localizations": "tsx scripts/db/seed-localizations.ts",
    "i18n:extract": "formatjs extract --format simple --preserve-whitespace 'src/**/*.ts*' --ignore='src/**/*.d.ts' --out-file src/lib/i18n/extracted/en-US.json",
    "i18n:compile": "formatjs compile-folder --format simple --ast ./src/lib/i18n/extracted ./src/lib/i18n/compiled && formatjs compile-folder --format simple --ast ./src/lib/i18n/translated ./src/lib/i18n/compiled",
    "prebuild": "pnpm i18n:compile"
  },
  "dependencies": {
    "@auth/drizzle-adapter": "^1.11.1",
    "@aws-sdk/client-s3": "^3.1008.0",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@formkit/auto-animate": "^0.9.0",
    "@hookform/resolvers": "^5.2.2",
    "@radix-ui/react-avatar": "^1.1.11",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-progress": "^1.1.8",
    "@radix-ui/react-radio-group": "^1.3.8",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-toggle": "^1.1.10",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@t3-oss/env-nextjs": "^0.13.10",
    "@tanstack/query-async-storage-persister": "^5.95.2",
    "@tanstack/react-query": "^5.90.21",
    "@tanstack/react-query-persist-client": "^5.95.2",
    "@tcgdex/sdk": "^2.7.1",
    "@trpc/client": "^11.11.0",
    "@trpc/react-query": "^11.11.0",
    "@trpc/server": "^11.11.0",
    "@trpc/tanstack-react-query": "^11.11.0",
    "@vercel/speed-insights": "^1.3.1",
    "browser-image-compression": "^2.0.2",
    "class-variance-authority": "^0.7.1",
    "client-only": "^0.0.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "dotenv": "^17.3.1",
    "drizzle-orm": "^0.45.1",
    "fuse.js": "^7.1.0",
    "lucide-react": "^0.576.0",
    "next": "16.1.6",
    "next-auth": "5.0.0-beta.30",
    "next-plausible": "^3.12.5",
    "next-themes": "^0.4.6",
    "nextjs-toploader": "^3.9.17",
    "pg": "^8.19.0",
    "radix-ui": "^1.4.3",
    "react": "^19.2.4",
    "react-device-detect": "^2.2.3",
    "react-dom": "^19.2.4",
    "react-hook-form": "^7.71.2",
    "react-image-crop": "^11.0.10",
    "react-intl": "^8.1.3",
    "react-responsive": "^10.0.1",
    "server-only": "^0.0.1",
    "sonner": "^2.0.7",
    "superjson": "^2.2.6",
    "tailwind-merge": "^3.5.0",
    "yet-another-react-lightbox": "^3.29.1",
    "zod": "^4.3.6",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.4",
    "@formatjs/cli": "^6.13.0",
    "@hookform/devtools": "^4.4.0",
    "@tailwindcss/postcss": "^4.2.1",
    "@total-typescript/ts-reset": "^0.6.1",
    "@types/node": "^25.3.3",
    "@types/pg": "^8.18.0",
    "@types/qrcode-terminal": "^0.12.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "cloudflared": "^0.7.1",
    "dotenv-cli": "^11.0.0",
    "drizzle-kit": "^0.31.9",
    "eslint": "^10.0.2",
    "eslint-config-next": "16.1.6",
    "prettier": "^3.8.1",
    "qrcode-terminal": "^0.12.0",
    "tailwindcss": "^4.2.1",
    "tsx": "^4.21.0",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5.9.3"
  }
}
